# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Admin email to receive contact forms
ADMIN_EMAIL=info@m62webtv.ne

# Public contact phone shown in auto-reply template
COMPANY_PHONE=08122221080

# Required for comments moderation endpoints
ADMIN_API_KEY=change-this-to-a-strong-key

# Auto-archive comments older than this many days
COMMENT_ARCHIVE_DAYS=180

# Comma-separated allowed frontend origins for CORS
FRONTEND_ORIGIN=https://your-frontend-domain.netlify.app

# MongoDB Atlas connection string for News CRUD
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional database name override
MONGODB_DB_NAME=m62_webtv

# If true and MONGODB_URI is empty, start an in-memory MongoDB instance for local development
MONGODB_INMEMORY_FALLBACK=true

# JWT settings for login/authentication
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXPIRES_IN=7d

# Creates initial admin account only if users collection is empty
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password

# Max upload size in MB for image uploads
UPLOAD_MAX_MB=10

# Max upload size in MB for video uploads
VIDEO_UPLOAD_MAX_MB=200

# Server port
PORT=3000

# For production, use:
# NODE_ENV=production
