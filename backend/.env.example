# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Admin email to receive contact forms
ADMIN_EMAIL=info@m62webtv.ne

# Public contact phone shown in auto-reply template
COMPANY_PHONE=08122221080

# Required for comments moderation endpoints
ADMIN_API_KEY=change-this-to-a-strong-key

# Auto-archive comments older than this many days
COMMENT_ARCHIVE_DAYS=180

# Comma-separated allowed frontend origins for CORS
FRONTEND_ORIGIN=https://your-frontend-domain.netlify.app

# Server port
PORT=3000

# For production, use:
# NODE_ENV=production
